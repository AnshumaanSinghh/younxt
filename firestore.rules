rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ──────────────────────────────────────────────
    // Helper Functions
    // ──────────────────────────────────────────────

    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the user is accessing their own data
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Validate string field length
    function isValidString(field, minLen, maxLen) {
      return field is string && field.size() >= minLen && field.size() <= maxLen;
    }

    // Validate array field size
    function isValidArray(field, maxLen) {
      return field is list && field.size() <= maxLen;
    }

    // ──────────────────────────────────────────────
    // User Profiles
    // ──────────────────────────────────────────────
    match /users/{userId} {
      // Users can only read their own profile
      allow read: if isAuthenticated() && isOwner(userId);

      // Users can create their own profile with validation
      allow create: if isAuthenticated() && isOwner(userId)
        && isValidString(request.resource.data.name, 1, 100)
        && isValidString(request.resource.data.email, 5, 254)
        && isValidArray(request.resource.data.goals, 10)
        && isValidArray(request.resource.data.hobbies, 10)
        && request.resource.data.onboarded == true;

      // Users can update their own profile (restricted fields)
      allow update: if isAuthenticated() && isOwner(userId)
        && (!request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['createdAt', 'email']));  // Prevent modifying createdAt and email

      // Users cannot delete their own profile (admin only)
      allow delete: if false;

      // ──────────────────────────────────────────────
      // User Logs Subcollection
      // ──────────────────────────────────────────────
      match /logs/{logId} {
        // Users can read their own logs
        allow read: if isAuthenticated() && isOwner(userId);

        // Users can create logs with validation
        allow create: if isAuthenticated() && isOwner(userId)
          && isValidString(request.resource.data.motivationalLine, 1, 1000)
          && isValidArray(request.resource.data.actionSteps, 10)
          && request.resource.data.completed == false;

        // Users can only update the 'completed' field
        allow update: if isAuthenticated() && isOwner(userId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['completed'])
          && request.resource.data.completed == true;

        // Users can delete their own logs (required for auto-cleanup)
        allow delete: if isAuthenticated() && isOwner(userId);
      }
    }

    // ──────────────────────────────────────────────
    // Default: Deny all other access
    // ──────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
